{
  "name": "pc-control-agent",
  "version": "1.1.0",
  "description": "PC Control Hub Agent with GUI",
  "author": {
    "name": "Nexus",
    "email": "support@nexus.local"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "prebuild": "node scripts/bake-installer-defaults.js",
    "build": "electron-builder build --win --x64 --publish never",
    "prebuild:dir": "node scripts/bake-installer-defaults.js",
    "build:dir": "electron-builder build --win --dir --x64",
    "bake-installer-defaults": "node scripts/bake-installer-defaults.js"
  },
  "dependencies": {
    "iconv-lite": "^0.7.2",
    "screenshot-desktop": "^1.15.3",
    "socket.io-client": "^4.8.3",
    "systeminformation": "^5.31.3",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "jsonwebtoken": "^9.0.3"
  },
  "build": {
    "appId": "com.nexus.pccontrol.agent",
    "productName": "Nexus Agent",
    "copyright": "Copyright (c) 2024-2025 Nexus",
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "ru"
    ],
    "directories": {
      "output": "dist-gui",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.js",
      "runtimeConfig.js",
      "installerDefaults.js",
      "installerDefaults.json",
      "paths.js",
      "metrics.js",
      "fileManager.js",
      "screenCapture.js",
      "vnc.js",
      "systemControl.js",
      "clipboard.js",
      "ui/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json",
      "!scripts/**",
      "!**/*.{md,markdown,test.js,spec.js}",
      "!**/{LICENSE,LICENSE.txt,LICENCE,LICENCE.txt,README.md,readme.md,CHANGELOG.md,changelog.md}",
      "!**/.git",
      "!.agent-id"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "Nexus-Agent-${version}.${ext}",
      "executableName": "Nexus Agent",
      "requestedExecutionLevel": "asInvoker",
      "publisherName": "Nexus"
    },
    "portable": {
      "artifactName": "Nexus-Agent-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nexus Agent",
      "menuCategory": "Nexus",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "uninstallDisplayName": "Nexus Agent ${version}",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "artifactName": "Nexus-Agent-Setup-${version}.${ext}"
    }
  }
}
